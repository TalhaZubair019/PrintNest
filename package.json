{
  "name": "printnest",
  "version": "0.1.0",
  "private": true,
  "description": "PrintNest - Custom print-on-demand store (Next.js + Express monorepo)",
  "scripts": {
    "dev:frontend": "cd frontend && npx next dev",
    "dev:backend": "npx nodemon backend/server.js",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "build": "cd frontend && npx next build",
    "start": "cd frontend && npx next start",
    "lint": "cd frontend && npx eslint"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@reduxjs/toolkit": "^2.11.2",
    "@stripe/stripe-js": "^8.8.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "framer-motion": "^12.30.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.563.0",
    "mongoose": "^8.2.0",
    "multer": "^1.4.5-lts.1",
    "next": "16.1.6",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-redux": "^9.2.0",
    "stripe": "^14.25.0",
    "tailwind-merge": "^3.4.0"
